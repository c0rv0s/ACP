{
  "compilerOptions": {
    "types": ["mocha", "node"],
    "typeRoots": ["../node_modules/@types"],
    "lib": ["es2022"],
    "module": "commonjs",
    "target": "es2022",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["tests/**/*.ts", "target/types/**/*.ts"]
}
